# Copy to .env and fill in real values. Required in both local dev and on Vercel.

# Free Postgres from https://neon.tech — copy the connection string from your project dashboard.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Generate with: openssl rand -base64 32   (or `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`)
AUTH_SECRET=""
